# Database Configuration
# SQLite (default)
DATABASE_URL=sqlite:///./chronos.db

# PostgreSQL (uncomment to use)
# DATABASE_URL=postgresql://username:password@localhost:5432/chronos_db

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000

# Google Gemini API for Explainability
GOOGLE_API_KEY=your_google_gemini_api_key_here

# Logging
LOG_LEVEL=INFO
